<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.aitoolbox.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/e80-0162/Desktop/tk/AI-Toolbox/pipeline/daily_run.sh</string>
  </array>

  <!-- 하루 여러 번 시도: 한 시각에 맥이 자고 있어도 다른 시각이 잡음.
       새 영상이 없으면 즉시 종료(무해)하고, processed.json 중복방지로 재처리 안 함. -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>30</integer></dict>
    <dict><key>Hour</key><integer>10</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>13</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Hour</key><integer>19</integer><key>Minute</key><integer>0</integer></dict>
  </array>

  <!-- 예약 시각에 맥이 잠들어 있었으면, macOS 가 깨어난 직후 놓친 작업을 1회 실행 -->
  <key>RunAtLoad</key>
  <false/>

  <key>WorkingDirectory</key>
  <string>/Users/e80-0162/Desktop/tk/AI-Toolbox</string>

  <key>StandardOutPath</key>
  <string>/Users/e80-0162/Desktop/tk/AI-Toolbox/pipeline/logs/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/e80-0162/Desktop/tk/AI-Toolbox/pipeline/logs/launchd.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/e80-0162/.local/bin</string>
  </dict>
</dict>
</plist>
